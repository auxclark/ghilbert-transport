# MongoDB connection string.
# Local example:      mongodb://127.0.0.1:27017/ghilbert_transport
# MongoDB Atlas ex.:   mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/ghilbert_transport
MONGODB_URI=mongodb://127.0.0.1:27017/ghilbert_transport

# Port the API server runs on
PORT=5000

# Simple passcode used to unlock the /admin page in the frontend.
# Change this to something private before you deploy.
ADMIN_PASSCODE=roostercrow123

# Comma-separated list of origins allowed to call this API (your frontend URL).
# Use * only for quick local testing.
CORS_ORIGIN=http://localhost:5173

# Optional: absolute path to a folder for storing uploaded rooster photos.
# Only needed in production if you've attached a persistent disk (e.g. on Render).
# Leave unset for local dev — defaults to backend/uploads.
# UPLOAD_DIR=/var/data/uploads
